{
  "permissions": {
    "allow": [
      "Bash(make compile)",
      "Bash(make test)",
      "Bash(make build)",
      "Bash(make e2e)",
      "Bash(make serve)",
      "Bash(make stop)",
      "Bash(make clean)",
      "Bash(npm test)",
      "Bash(node scripts/*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git show*)",
      "Bash(git restore*)",
      "Bash(git checkout *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(find raw/**)",
      "Bash(find scripts/**)",
      "Bash(cat raw/**)",
      "Bash(cat scripts/**)",
      "Bash(mkdir -p .claude/**)",
      "Bash(bash .claude/hooks/*)",
      "Read",
      "Edit(raw/**)",
      "Edit(scripts/**)",
      "Edit(specs/**)",
      "Edit(.claude/**)",
      "Edit(CLAUDE.md)",
      "Edit(Makefile)",
      "Edit(README.md)",
      "Write(raw/**)",
      "Write(.claude/**)",
      "Write(specs/**)"
    ],
    "deny": [
      "Edit(docs/data.js)",
      "Edit(docs/nodes.json)",
      "Edit(docs/references.json)",
      "Write(docs/data.js)",
      "Write(docs/nodes.json)",
      "Write(docs/references.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-drift.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-compile.sh"
          }
        ]
      }
    ]
  }
}
